{
  "mcpServers": {
    "codegraph": {
      "type": "stdio",
      "command": "node",
      "args": [
        "C:\\Users\\Futur\\Documents\\AiWorkspace\\Claude\\codegraph-nv-bridge.js"
      ]
    },
    "nv-web": {
      "type": "stdio",
      "command": "node",
      "args": [
        "C:\\Users\\Futur\\Documents\\AiWorkspace\\Claude\\nv-web-mcp.js"
      ]
    },
    "claude-flow": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "ruflo@latest",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "15",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid"
      },
      "autoStart": false
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "v0": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.v0.dev",
        "--header",
        "Authorization: Bearer ${V0_API_KEY}"
      ]
    }
  }
}
